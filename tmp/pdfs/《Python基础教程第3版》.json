    "teaching_use": {
      "role": "主知识来源",
      "style": "内容主线跟随本书，讲解表达参考教程式写法，练习和案例按项目导向增强",
      "usage_rule": [
        "先按本书章节决定当天学什么",
        "优先抽取概念、最小示例、注意点和练习切入点",
        "不要把整本书重写成百科",
        "只保留和当前学习主线直接相关的内容"
      ]
    },
    "recommended_path": [
      {
        "stage": "基础语法与数据结构",
        "chapters": [
          "数据类型和变量",
          "字符串和编码",
          "使用list和tuple",
          "条件判断",
          "循环",
          "使用dict和set"
        ],
        "goal": "建立 Python 基础语法、数据类型和控制流直觉"
      },
      {
        "stage": "函数与抽象",
        "chapters": [
          "调用函数",
          "定义函数",
          "函数的参数",
          "递归函数"
        ],
        "goal": "把零散逻辑整理成可复用函数，理解参数、返回值和职责边界"
      },
      {
        "stage": "脚本能力与数据处理",
        "chapters": [
          "切片",
          "迭代",
          "列表生成式",
          "生成器",
          "迭代器"
        ],
        "goal": "开始具备处理文本、序列和小型数据流的能力"
      },
      {
        "stage": "模块化与工程基础",
        "chapters": [
          "模块",
          "面向对象编程",
          "错误、调试和测试",
          "IO编程",
          "进程和线程"
        ],
        "goal": "从脚本走向可维护代码，补齐模块组织、IO、错误处理和工程基本面"
      }
    ],
    "current_focus_recommendation": {
      "topic": "函数参数与返回值设计",
      "book_sections": [
        "调用函数",
        "定义函数",
        "函数的参数"
      ],
      "why_now": [
        "这是脚本拆分前的关键前置知识",
        "当前学习状态里，函数接口设计仍不稳定",
        "后续模块拆分会直接依赖这部分"
      ],
      "should_emphasize": [
        "参数是什么",
        "返回值是什么",
        "默认参数为什么存在",
        "为什么一个函数不要做太多事"
      ]
    },
    "content_extraction_rules": [
      "lesson 优先提取：概念解释、最小示例、注意点",
      "exercises 优先提取：书中对应练习思路，再增强为工程场景题",
      "answers 必须补上为什么这样设计更好，而不是只给结果",
      "可以增加 JS/TS 类比，但不能喧宾夺主"
