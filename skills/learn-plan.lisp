;;; -*- mode: emacs-lisp; lexical-binding: t; -*-
;;; learn-plan.lisp --- Python 学习内容输出规划
;;;
;;; 迁移说明：
;;; - 目录规则、知识边界审查、lesson / practice 结构已拆分到
;;;   `skills/shared/knowledge-boundary-check.md`
;;;   `skills/templates/daily-lesson-template.md`
;;;   `skills/templates/daily-practice-template.md`
;;;   `skills/templates/week-plan-template.md`
;;; - 本文件继续保留为最初版本，避免直接破坏原有部署。

(require 'cl-lib)

(defconst 学习计划/定位
  '((名称 . "学习内容规划器")
    (职责 . ("定义每天学习产物的文件结构"
            "约束 lesson 与 practice 的内容质量"
            "确保练习文件可被 AI 检查、纠错、复盘"))
    (适用场景 . "为前端转 Python / AI Agent 的学习者生成每日学习包"))
  "学习计划器的定位。")

(defconst 学习计划/目录规则
  '((默认目录 . "study/dayN/")
    (默认文件 . ("lesson.md" "practice.py"))
    (可选命名 . "如果主题强依赖独立脚本名，可用 topic_name.py，但内容结构不能缩水"))
  "每天学习内容的目录和文件规则。")

(defconst 学习计划/知识边界规则
  '((触发时机 . ("生成整周学习包前"
              "生成整天学习包前"))
    (生成前检查 . ("先读取当前计划中的主题、任务和显式知识点"
                "列出本次允许出现的语法点、API、内置函数、方法、模块"
                "列出学习者已经学过、可以直接复用的前置知识"
                "把 lesson 和练习里准备出现的调用逐项比对，检查是否超纲"))
    (超纲判断 . ("凡是不属于“已学知识”或“本次明确要学知识”的 API / 内置函数 / 方法 / 模块，都视为超纲"
              "如果练习依赖某个未声明知识点，也视为超纲"))
    (补洞策略 . ("如果超纲点只有 1~3 个且绕不开，先在 lesson 里增加“先补 5 分钟”小节"
              "如果超纲点已经影响主线理解，先补一个独立前置知识块，再进入正式内容"
              "补洞完成后，再重跑一次知识边界检查"))
    (生成后复核 . ("核对 lesson 的示例区、练习文件的示例区、练习区、检查标准里出现的 API"
                "确保每个调用都能归到：已学过 / 今天新学 / 今天先补"
                "如果无法归类，回退并修改学习包")))
  "生成整周 / 整天学习包时必须执行的知识边界审查规则。")

(defconst 学习计划/提纲式lesson规则
  '((适用场景 . ("周计划派生的每日 lesson"
              "需要保持学习笔记节奏的 daily lesson"))
    (默认章节 . ("今天只学什么"
              "来源绑定"
              "今天目标"
              "参数级重点"
              "JS / TS 桥接"
              "今天任务"
              "今日最小结论"
              "理解检查"))
    (展开要求 . ("保留提纲结构，但每一节都要补解释、例子或判断点，不能只剩标题和一句定义"
                "今天目标除了说学什么，还要解释为什么现在学、和前一天怎么衔接"
                "参数级重点不能只列 API 名称；每个重点至少讲清：它是什么、效果或返回值、最小示例、常见用途"
                "如果任务之间本来就是一条小流程，必须补一个“一个连起来的小例子”或等价的小流程示例"
                "如果当天引入拆文件、工程化、对象化等新习惯，必须额外解释“为什么现在要这样做”"
                "JS / TS 桥接不能只停在表面类比，要明确哪里相似、哪里不能硬套"
                "复杂主题和连接主题必须补常见误区或常见坑，防止 lesson 退化成提纲"
                "理解检查必须具体指向今天的判断点，不能只问“明白了吗”"))
    (风格边界 . ("保持学习笔记式结构，不要突然改写成百科教程"
               "解释要偏初学者，但仍然克制、可扫读"
               "优先用短段落 + 小例子推进，而不是长篇堆砌")))
  "提纲式 daily lesson 的默认结构和展开规则。")

(defun 学习计划/提纲式lesson章节 (复杂度)
  "提纲式 lesson.md 必备章节。"
  (append
   '("今天只学什么"
     "来源绑定"
     "今天目标"
     "参数级重点"
     "JS / TS 桥接"
     "今天任务")
   (cond
    ((equal 复杂度 '基础主题)
     '("最小示例"
       "常见误区"))
   ((equal 复杂度 '连接主题)
     '("一个连起来的小例子"
       "常见误区"))
    (t
     '("一个连起来的小例子"
       "为什么现在要这样做"
       "常见误区")))
   '("今日最小结论"
     "理解检查")))

(defun 学习计划/lesson章节 (复杂度)
  "lesson.md 必备章节。"
  (append
   '("今天目标"
     "前置知识"
     "今天会新接触的 API / 内置函数 / 方法"
     "先补 5 分钟：如果你没学过这些"
     "今天的知识边界"
     "核心直觉"
     "JS / TS 桥接理解"
     "Python 真实语义"
     "最小可运行示例"
     "常见误区"
     "AI / Agent 关联"
     "今日最小结论"
     "理解检查")
   (cond
    ((equal 复杂度 '基础主题)
     '("一个最小练习"))
    ((equal 复杂度 '连接主题)
     '("执行过程拆解"
       "真实场景示例"
       "两个层次的练习"))
    (t
     '("执行过程拆解"
       "扩展示例"
       "边界与常见报错"
       "三段式练习：热身 / 动手 / 排错")))))

(defun 学习计划/practice章节 ()
  "practice.py 或主题练习文件的必备结构。"
  '("文件头说明：本文件如何运行、如何作答"
    "本文件会用到的新内容清单：列出本练习显式出现的新 API / 方法 / 内置函数"
    "示例区：给最小可运行示例"
    "练习1：补全代码 / 预测输出"
    "练习2：按要求改写或独立实现"
    "练习3：找 bug / 解释报错 / 解释执行过程"
    "作答区：使用 TODO / START / END 明确留白"
    "检查标准：期望输出、判断标准或通过条件"
    "AI 批改说明：学习者需要附带代码、运行结果、理解、卡点"))

(defun 学习计划/输出质量规则 ()
  "生成 daily package 时必须满足的质量规则。"
  '("lesson.md 负责解释，practice.py 负责作答，不要把两者混成一份空讲义"
    "任何练习文件都不能只有示例，没有题目和留白"
    "任何 lesson 文件都不能只有定义，没有推理和例子"
    "如果使用提纲式 lesson 结构，关键章节下面必须补解释段落，不能只像目录"
    "参数级重点不能只列 API / 方法名，必须至少补含义、最小示例和常见用途"
    "如果今天任务天然能串成一个流程，lesson 里必须补一个连起来的小例子"
    "如果 lesson 开始引入工程化习惯或代码拆分，必须解释为什么这一步现在出现"
    "基础主题保持轻量，但复杂主题必须明确加深"
    "所有练习都要能被 AI 检查、纠错、复盘"
    "生成整周 / 整天学习包前，必须先做知识清单和超纲审查"
    "练习里出现的 API / 内置函数 / 方法，必须能在已学过、本次要学、或补洞知识里找到出处"
    "如果发现超纲点，先补洞，再生成正式 lesson 和练习"
    "生成后再做一次逐项复核：示例区、练习区、检查标准不能偷偷带入未声明知识"))

(defun 学习计划/学习包审查流程 ()
  "生成整周 / 整天学习包时的固定检查流程。"
  '("步骤1：读取当前计划，抽出本次主题、任务和显式知识点"
    "步骤2：列出本次学习包允许出现的语法点、API、内置函数、方法、模块"
    "步骤3：列出学习者已学过、可直接复用的相关知识"
    "步骤4：扫描 lesson 示例区、练习示例区、练习题中的所有调用"
    "步骤5：标记超纲点，并判断是“小补洞”还是“独立前置知识块”"
    "步骤6：补洞完成后重跑检查"
    "步骤7：生成后再次核对，确保没有漏网之鱼"))

(defun 学习计划/AI批改提交流程 ()
  "学习者向 AI 提交练习时的最小信息集合。"
  '("题目名称"
    "我写的代码"
    "我的运行命令"
    "我的运行结果或报错"
    "我自己的理解"
    "我希望 AI 重点检查的地方"))

(defun 程序员学习计划模板 (天数 主题 复杂度)
  "输出某一天学习包的模板。"
  (list
   (cons '第几天 天数)
   (cons '学习主题 主题)
   (cons '复杂度 复杂度)
   (cons '目录规则 学习计划/目录规则)
   (cons '知识边界规则 学习计划/知识边界规则)
   (cons '提纲式lesson规则 学习计划/提纲式lesson规则)
   (cons '提纲式lesson章节 (学习计划/提纲式lesson章节 复杂度))
   (cons 'lesson章节 (学习计划/lesson章节 复杂度))
   (cons 'practice章节 (学习计划/practice章节))
   (cons '质量规则 (学习计划/输出质量规则))
   (cons '学习包审查流程 (学习计划/学习包审查流程))
   (cons 'AI批改提交 (学习计划/AI批改提交流程))))

;;; ===== 使用约束 =====
;;; 1. 每天至少产出 lesson.md 和 practice.py 两个文件
;;; 2. lesson 负责讲解，practice 负责练习与作答
;;; 3. practice 文件必须有题目、留白和检查标准
;;; 4. 复杂主题必须在 lesson 里增加执行过程拆解和扩展示例
;;; 5. 生成后先检查：是否出现“只有示例，没有练习”的退化
;;; 6. 生成后再检查：AI 是否能仅凭学习者提交的信息完成批改
;;; 7. 生成整周 / 整天学习包前，必须先做知识边界审查
;;; 8. 如果发现超纲 API / 内置函数 / 方法，先补洞再生成正式内容
;;; 9. 生成后必须逐项复核：示例区、练习区、检查标准里的调用都不能超纲
;;; 10. 如果采用提纲式 lesson，不能只给提纲标题；每一节都要补解释和例子
;;; 11. 参数级重点必须展开到“含义 + 示例 + 用途”，不能只列 API 名称
;;; 12. 如果任务之间能串起来，必须补一个连起来的小例子

(程序员学习计划模板
 1
 "Python 的列表和字典"
 '连接主题)
